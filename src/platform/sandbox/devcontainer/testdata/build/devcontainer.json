// JSONC with comment — should parse fine
{
  "name": "test-build",
  "build": {
    "dockerfile": "Dockerfile", // relative path
    "context": ".",
    "name": "test-build:latest" // roost extension: image name to use after building
  },
  "remoteUser": "vscode",
  "containerEnv": {
    "PROJECT_VAR": "from_project"
  },
  "mounts": ["source=/host/data,target=/data,type=bind"],
  "runArgs": ["--network=host"]
}
